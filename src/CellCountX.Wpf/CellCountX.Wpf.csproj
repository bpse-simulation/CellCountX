<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon>favicon_bpse.ico</ApplicationIcon>
  </PropertyGroup>

  <!-- ZIP ファイルを Item として定義 -->
  <ItemGroup>
    <PythonZip Include="python-3.10.11-embed-amd64.zip" />
  </ItemGroup>

  <!-- ============================
       ZIP 展開（Build / Publish 共通）
       ============================ -->
  <Target Name="ExtractPythonZip"
          BeforeTargets="CopyPythonOnBuild;CopyPythonOnPublish"
          Condition="'$(Configuration)' == 'Release'">

    <!-- ZIP と同名フォルダを展開先にする -->
    <PropertyGroup>
      <PythonExtractDir>$(IntermediateOutputPath)%(PythonZip.Filename)\</PythonExtractDir>
    </PropertyGroup>

    <MakeDir Directories="$(PythonExtractDir)" />

    <Unzip SourceFiles="@(PythonZip)"
           DestinationFolder="$(PythonExtractDir)" />
  </Target>

  <!-- ============================
       Build 時のコピー
       ============================ -->
  <Target Name="CopyPythonOnBuild"
          AfterTargets="Build"
          Condition="'$(Configuration)' == 'Release'">

    <ItemGroup>
      <!-- 展開された Python -->
      <ExtractedPythonFiles Include="$(PythonExtractDir)**\*" />

      <!-- cellpose ライブラリ -->
      <PythonFiles Include="..\CellCountX.Py\cellpose\Lib\**\*"
                   Exclude="..\CellCountX.Py\cellpose\pyvenv.cfg;7
                            ..\CellCountX.Py\cellpose\.gitignore" />
    </ItemGroup>

    <!-- 展開した Python をコピー -->
    <Copy SourceFiles="@(ExtractedPythonFiles)"
          DestinationFolder="$(OutDir)python\%(RecursiveDir)" />

    <!-- cellpose ライブラリ -->
    <Copy SourceFiles="@(PythonFiles)"
          DestinationFolder="$(OutDir)python\%(RecursiveDir)" />

    <!-- pth -->
    <Copy SourceFiles="python_embed\python310._pth.template"
          DestinationFiles="$(OutDir)python\python310._pth" />

    <!-- server.py -->
    <Copy SourceFiles="..\CellCountX.Py\server.py"
          DestinationFolder="$(OutDir)" />

    <!-- nonadherent_filter.py -->
    <Copy SourceFiles="..\CellCountX.Py\nonadherent_filter.py"
          DestinationFolder="$(OutDir)" />
  </Target>

  <!-- ============================
       Publish 時のコピー
       ============================ -->
  <Target Name="CopyPythonOnPublish"
          AfterTargets="Publish"
          Condition="'$(Configuration)' == 'Release'">

    <ItemGroup>
      <ExtractedPythonFiles Include="$(PythonExtractDir)**\*" />
      <PythonFiles Include="..\CellCountX.Py\cellpose\Lib\**\*"
                   Exclude="..\CellCountX.Py\cellpose\pyvenv.cfg;
                            ..\CellCountX.Py\cellpose\.gitignore" />
    </ItemGroup>

    <!-- 展開した Python をコピー -->
    <Copy SourceFiles="@(ExtractedPythonFiles)"
          DestinationFolder="$(PublishDir)python\%(RecursiveDir)" />

    <!-- cellpose ライブラリ -->
    <Copy SourceFiles="@(PythonFiles)"
          DestinationFolder="$(PublishDir)python\%(RecursiveDir)" />

    <!-- pth -->
    <Copy SourceFiles="python_embed\python310._pth.template"
          DestinationFiles="$(PublishDir)python\python310._pth" />

    <!-- server.py -->
    <Copy SourceFiles="..\CellCountX.Py\server.py"
          DestinationFolder="$(PublishDir)" />

    <!-- nonadherent_filter.py -->
    <Copy SourceFiles="..\CellCountX.Py\nonadherent_filter.py"
          DestinationFolder="$(PublishDir)" />
  </Target>

  <!-- ============================
       Clean 時に python/ と server.py と nonadherent_filter.py を削除
       ============================ -->
  <Target Name="CleanCopiedPython"
          BeforeTargets="Clean"
          Condition="'$(Configuration)' == 'Release'">

    <!-- Build 出力 -->
    <RemoveDir Directories="$(OutDir)python" />
    <Delete Files="$(OutDir)server.py" />
    <Delete Files="$(OutDir)nonadherent_filter.py" />

    <!-- Publish 出力 -->
    <RemoveDir Directories="$(PublishDir)python" />
    <Delete Files="$(PublishDir)server.py" />
    <Delete Files="$(PublishDir)nonadherent_filter.py" />
  </Target>

  <!-- ============================
       アイコン
       ============================ -->
  <ItemGroup>
    <Content Include="favicon_bpse.ico" />
  </ItemGroup>

  <ItemGroup>
    <Compile Update="Properties\Settings.Designer.cs">
      <DesignTimeSharedInput>True</DesignTimeSharedInput>
      <AutoGen>True</AutoGen>
      <DependentUpon>Settings.settings</DependentUpon>
    </Compile>
  </ItemGroup>

  <ItemGroup>
    <None Update="Properties\Settings.settings">
      <Generator>SettingsSingleFileGenerator</Generator>
      <LastGenOutput>Settings.Designer.cs</LastGenOutput>
    </None>
  </ItemGroup>

</Project>
