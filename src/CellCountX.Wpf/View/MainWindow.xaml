<Window x:Class="CellCountX.Wpf.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CellCountX.Wpf.ViewModel"
        mc:Ignorable="d"
        Title="CellCountX" Height="500" Width="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 0. 入力フォルダ -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="画像フォルダ：" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Text="{Binding InputFolder, Mode=TwoWay}" Width="500" Margin="0,0,10,0"/>
            <Button Content="参照..." Command="{Binding BrowseFolderCommand}" Width="80"/>
        </StackPanel>

        <!-- 1. 出力フォルダ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
            <TextBlock Text="出力フォルダ：" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBox Text="{Binding OutputFolder, Mode=TwoWay}" Width="500" Margin="0,0,10,0"/>
            <Button Content="参照..." Command="{Binding BrowseOutputFolderCommand}" Width="80"/>
        </StackPanel>

        <!-- 2. GPU -->
        <CheckBox Grid.Row="2"
                  Content="GPU を使用する"
                  IsChecked="{Binding UseGpu, Mode=TwoWay}"
                  Margin="0,10,0,10"
                  FontSize="14"/>

        <!-- 3. タイムアウト -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="タイムアウト（秒）：" VerticalAlignment="Center"/>
            <TextBox Text="{Binding TimeoutSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Width="80" Margin="10,0,0,0"/>
        </StackPanel>

        <!-- 4. ログ -->
        <GroupBox Grid.Row="4" Header="ログ" Margin="0,10,0,10">
            <ScrollViewer x:Name="LogScrollViewer"
                          VerticalScrollBarVisibility="Auto">
                <TextBlock Text="{Binding LogText}"
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           Margin="5"/>
            </ScrollViewer>
        </GroupBox>

        <!-- 5. 実行ボタン -->
        <StackPanel Grid.Row="5" Orientation="Vertical">
            <ProgressBar Height="20"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding ProgressValue}"
                         Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="開始"
                        Command="{Binding StartBatchCommand}"
                        Width="100" Margin="0,0,10,0"/>

                <Button Content="キャンセル"
                        Command="{Binding CancelBatchCommand}"
                        Width="100"/>
            </StackPanel>
        </StackPanel>

    </Grid>
</Window>
