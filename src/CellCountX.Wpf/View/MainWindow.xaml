<Window x:Class="CellCountX.Wpf.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CellCountX.Wpf.ViewModel"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        d:DataContext="{d:DesignInstance Type=local:MainViewModel}"
        mc:Ignorable="d"
        Title="CellCountX"
        Height="650"
        Width="900">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <DockPanel>

        <!-- メニューバー -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="詳細設定" Click="OpenAdvancedSettings"/>
                <MenuItem Header="終了(_X)" Click="Exit_Click"/>
            </MenuItem>

            <MenuItem Header="ヘルプ(_H)">
                <MenuItem Header="バージョン情報(_A)" Click="OpenAboutWindow"/>
            </MenuItem>
        </Menu>

        <!-- メインコンテンツ -->
        <Grid Margin="20" DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 入力フォルダ -->
                <RowDefinition Height="Auto"/>
                <!-- 出力フォルダ -->
                <RowDefinition Height="Auto"/>
                <!-- GPU -->
                <RowDefinition Height="Auto"/>
                <!-- 非接着細胞除去 ON/OFF -->
                <RowDefinition Height="Auto"/>
                <!-- 非接着細胞除去 -->
                <RowDefinition Height="*"/>
                <!-- ログ -->
                <RowDefinition Height="Auto"/>
                <!-- 実行ボタン -->
            </Grid.RowDefinitions>

            <!-- 0. 入力フォルダ -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="画像フォルダ：" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding InputFolder, Mode=TwoWay}"
                         Margin="0,0,10,0"/>

                <Button Grid.Column="2"
                        Content="参照..."
                        Command="{Binding BrowseFolderCommand}"
                        Width="80"/>
            </Grid>

            <!-- 1. 出力フォルダ -->
            <Grid Grid.Row="1" Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="出力フォルダ：" VerticalAlignment="Center" Margin="0,0,10,0"/>

                <TextBox Grid.Column="1"
                         Text="{Binding OutputFolder, Mode=TwoWay}"
                         Margin="0,0,10,0"/>

                <Button Grid.Column="2"
                        Content="参照..."
                        Command="{Binding BrowseOutputFolderCommand}"
                        Width="80"/>
            </Grid>

            <!-- 2. GPU -->
            <CheckBox Grid.Row="2"
                      Content="GPU を使用する"
                      IsChecked="{Binding UseGpu, Mode=TwoWay}"
                      Margin="0,10,0,10"
                      FontSize="14"/>

            <!-- 3. 非接着細胞除去 ON/OFF -->
            <CheckBox Grid.Row="3"
                      Content="非接着細胞除去を有効にする"
                      IsChecked="{Binding RemoveNonAdherents, Mode=TwoWay}"
                      Margin="0,10,0,10"
                      FontSize="14"/>

            <!-- 4. 非接着細胞除去パラメータ -->
            <GroupBox Grid.Row="4"
                      Header="非接着細胞除去（Cellpose 後処理）"
                      Margin="0,10,0,10"
                      Visibility="{Binding RemoveNonAdherents, Converter={StaticResource BoolToVis}}">
                <StackPanel Margin="10">

                    <UniformGrid Columns="2" Rows="4" Margin="0,5,0,0">

                        <TextBlock Text="最小面積 (min_area)" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MinArea, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F0}"
                     Width="80" Margin="5" HorizontalAlignment="Right"/>

                        <TextBlock Text="最大円形度 (max_circularity)" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MaxCircularity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F3}"
                     Width="80" Margin="5" HorizontalAlignment="Right"/>

                        <TextBlock Text="最大輝度 (max_intensity)" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MaxIntensity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F1}"
                     Width="80" Margin="5" HorizontalAlignment="Right"/>

                        <TextBlock Text="最小分散 (min_variance)" VerticalAlignment="Center"/>
                        <TextBox Text="{Binding MinVariance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                     Width="80" Margin="5" HorizontalAlignment="Right"/>

                    </UniformGrid>
                </StackPanel>
            </GroupBox>

            <!-- 5. ログ -->
            <GroupBox Grid.Row="5" Header="ログ" Margin="0,10,0,10">
                <ScrollViewer x:Name="LogScrollViewer"
                              VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding LogText}"
                               TextWrapping="Wrap"
                               FontFamily="Consolas"
                               Margin="5"/>
                </ScrollViewer>
            </GroupBox>

            <!-- 6. 実行ボタン -->
            <StackPanel Grid.Row="6" Orientation="Vertical">
                <ProgressBar Height="20"
                             Minimum="0"
                             Maximum="100"
                             Value="{Binding ProgressValue}"
                             Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="開始"
                            Command="{Binding StartBatchCommand}"
                            Width="100" Margin="0,0,10,0"/>

                    <Button Content="キャンセル"
                            Command="{Binding CancelBatchCommand}"
                            Width="100"/>
                </StackPanel>
            </StackPanel>

        </Grid>
    </DockPanel>
</Window>
